# Alpaca Markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Groq API
GROQ_API_KEY=your_groq_api_key

# Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twelve Data
TWELVE_DATA_API_KEY=your_twelve_data_api_key
TWELVE_DATA_CACHE_MINUTES=15

# Company logos
LOGO_DEV_PUBLISHABLE_KEY=your_logo_dev_publishable_key

# MinIO / local S3
# Use strong unique credentials in production.
MINIO_ROOT_USER=change_me_minio_user
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me_minio_user
MINIO_SECRET_KEY=change_me_minio_password

# Storage
S3_BUCKET=finsight
ICEBERG_WAREHOUSE=s3://finsight/warehouse

# DuckDB
DUCKDB_PATH=/data/finsight.duckdb

# API hardening
FINSIGHT_ENV=development
FINSIGHT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FINSIGHT_ALLOWED_HOSTS=localhost,127.0.0.1,api
