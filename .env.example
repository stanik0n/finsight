# Alpaca Markets (get from alpaca.markets - free paper account)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Groq API (get free key from console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Telegram alerts — Phase 2 (create a bot via @BotFather, get chat ID via @userinfobot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# MinIO (local S3 - these are the credentials you set for your local MinIO instance)
MINIO_ROOT_USER=finsight
MINIO_ROOT_PASSWORD=finsight123
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=finsight
MINIO_SECRET_KEY=finsight123

# Storage
S3_BUCKET=finsight
ICEBERG_WAREHOUSE=s3://finsight/warehouse

# DuckDB (shared file on the data volume)
DUCKDB_PATH=/data/finsight.duckdb

